#############################################
# Aegis Fraud Guard - Example Environment
#############################################

# App
APP_NAME=Aegis Fraud Guard
APP_VERSION=0.1.0
APP_ENV=dev

# Kafka (services/inference_api.settings)
KAFKA_BROKER=PLAINTEXT://kafka:9092
KAFKA_TOPICS_IN=payments,sms,email
KAFKA_TOPIC_ALERTS=alerts
KAFKA_GROUP_ID=fraud-inference

# Redis
REDIS_URL=redis://redis:6379/0

# Prometheus exporter (custom/service metrics)
PROMETHEUS_PORT=9000

# Model
MODEL_DIR=/models
MODEL_NAME=fraud_xgb.json
SCORE_THRESHOLD=0.85
TOP_K_EXPLANATIONS=3
MAX_QUEUE_BACKLOG=10000

# REST API service
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
SERVICE_NAME=inference_api

# Monitoring stack
PROMETHEUS_MULTIPROC_DIR=/tmp/prom
PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Back-compat variables used by some components in this repo
KAFKA_BROKERS=redpanda:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
